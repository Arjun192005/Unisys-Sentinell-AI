PORT=3001
NODE_ENV=development
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:1.5b
DB_PATH=./data/sessions.db
CORS_ORIGIN=http://localhost:3000

# ─── SentinelAI Gateway ───────────────────────────────────────────────────────
SENTINEL_BASE_URL=http://localhost:8000
SENTINEL_ANALYZE_PATH=/analyze-advanced
# Shared internal secret — add this header check to SentinelAI if desired
SENTINEL_INTERNAL_KEY=sentinel-internal-key-2026

# ─── Demo Users (hardcoded for localhost demo — separate from SentinelAI users) ─
# Format: EMAIL:PASSWORD:ROLE
# NOTE: These are Agentic AI demo accounts only.
#       SentinelAI uses its own accounts (admin@sentinell.ai etc.)
#       When deploying to cloud, replace these with real auth.
DEMO_USER_1=admin@agenticai.demo:AgentAdmin@2026:ADMIN
DEMO_USER_2=employee@agenticai.demo:AgentEmp@2026:EMPLOYEE
DEMO_USER_3=intern@agenticai.demo:AgentIntern@2026:INTERN
